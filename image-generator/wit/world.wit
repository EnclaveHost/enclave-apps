// image-generator: SD-Turbo text-to-image compiled into a wasm component
// with a built-in web UI. Same world as llm-chat: imports wasi:nn (the GPU
// interface bought with gpuShare), exports the wasi:http handler. WIT deps
// are vendored verbatim from wasmtime v45 (wasi@0.2.6,
// wasi:nn@0.2.0-rc-2024-10-28) so guest and host always agree.
package enclave:image-generator;

world image-generator {
  import wasi:nn/tensor@0.2.0-rc-2024-10-28;
  import wasi:nn/errors@0.2.0-rc-2024-10-28;
  import wasi:nn/inference@0.2.0-rc-2024-10-28;
  import wasi:nn/graph@0.2.0-rc-2024-10-28;
  export wasi:http/incoming-handler@0.2.6;
}
